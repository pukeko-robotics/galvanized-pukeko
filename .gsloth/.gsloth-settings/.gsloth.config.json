{
  "llm2": {
    "type": "openrouter",
    "model": "moonshotai/kimi-k2"
  },
  "llm": {
    "type": "openrouter",
    "model": "google/gemini-2.5-pro"
  },
  "prompts": {
    "guidelines": "GUIDELINES.md"
  },
  "commands": {
    "code": {
      "filesystem": "all",
      "builtInTools": {
        "gth_checklist": true,
        "gth_grep": true,
        "run_build": { "command": "build-ui-server" },
        "run_lint": { "command": "pnpm -r run lint" },
        "run_tests": { "command": "pnpm -r run test" },
        "run_single_test": { "command": "pnpm --filter ./packages/${testPath} run test" }
      }
    }
  }
}
