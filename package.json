{
  "name": "galvanized-pukeko-ai-ui",
  "version": "0.0.1",
  "private": true,
  "description": "Give your LLM agent a real UI: a Vue 3 component library that renders forms, charts, tables and interactive A2UI surfaces over the AG-UI protocol, with reference AG-UI backends.",
  "author": "Andrew Kondratev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Galvanized-Pukeko/galvanized-pukeko-ai-ui.git"
  },
  "homepage": "https://github.com/Galvanized-Pukeko/galvanized-pukeko-ai-ui#readme",
  "bugs": "https://github.com/Galvanized-Pukeko/galvanized-pukeko-ai-ui/issues",
  "type": "module",
  "scripts": {
    "web": "npm run dev -w packages/galvanized-pukeko-web-client",
    "web-ag-ui": "AGUI_URL=http://localhost:3000/agents/default/run npm run dev -w packages/galvanized-pukeko-web-client",
    "sink": "npm run sink -w packages/galvanized-pukeko-web-client",
    "it-adk": "node it-adk.js",
    "it-adk-headed": "node it-adk.js --headed",
    "it-gth-ag-ui": "node it-gth-ag-ui.js",
    "start-adk": "node start-adk.js",
    "start-gth-ag-ui": "node start-gth-ag-ui.js"
  },
  "overrides": {
    "uuid": ">=11.1.1"
  },
  "dependencies": {
    "@gaunt-sloth/agent": "file:../gaunt-sloth-assistant/packages/agent",
    "@langchain/openai": "^1.4.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/ws": "^8.18.1",
    "express": "^5.2.1",
    "vue": "^3.5.13",
    "ws": "^8.21.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^10.5.0",
    "eslint-plugin-oxlint": "^0.16.12",
    "eslint-plugin-vue": "^10.9.2",
    "jiti": "^2.7.0",
    "jsdom": "^26.1.0",
    "oxlint": "^0.16.12",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^2.2.12"
  },
  "workspaces": [
    "packages/galvanized-pukeko-vue-ui",
    "packages/galvanized-pukeko-web-client"
  ],
  "allowScripts": {
    "esbuild@0.27.7": true
  }
}
