{
  "name": "@galvanized-pukeko/web-client",
  "version": "0.0.2",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "dev": "vite",
    "sink": "vite --open /sink/",
    "build": "npm run type-check && npm run build-only",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint": "oxlint . --fix -D correctness --ignore-path .gitignore && eslint . --fix",
    "format": "prettier --write packages/web/src/"
  },
  "author": "Andrew Kondratev",
  "license": "MIT",
  "private": true,
  "description": "Thin host app that mounts @galvanized-pukeko/vue-ui — the dev server and the build embedded by the ADK agent.",
  "dependencies": {
    "@copilotkit/vue": "^1.60.1",
    "@galvanized-pukeko/vue-ui": "^0.0.16",
    "chart.js": "^4.5.1",
    "zod": "^3.25.76"
  }
}
