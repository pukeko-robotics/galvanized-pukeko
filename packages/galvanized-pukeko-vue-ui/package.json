{
  "name": "@galvanized-pukeko/vue-ui",
  "version": "0.1.2-alpha.1",
  "description": "Vue 3 component library that lets an LLM agent render real UI — chat, forms, charts, tables and interactive A2UI surfaces — over the AG-UI protocol.",
  "author": "Andrew Kondratev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pukeko-robotics/galvanized-pukeko.git",
    "directory": "packages/galvanized-pukeko-vue-ui"
  },
  "homepage": "https://github.com/pukeko-robotics/galvanized-pukeko/tree/main/packages/galvanized-pukeko-vue-ui#readme",
  "bugs": "https://github.com/pukeko-robotics/galvanized-pukeko/issues",
  "keywords": [
    "vue",
    "vue3",
    "ag-ui",
    "a2ui",
    "agent",
    "llm",
    "ai",
    "generative-ui",
    "chat",
    "components"
  ],
  "type": "module",
  "main": "dist/vue-ui.umd.js",
  "module": "dist/vue-ui.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-ui.es.js",
      "require": "./dist/vue-ui.umd.js"
    },
    "./copilot": {
      "types": "./dist/copilot.d.ts",
      "import": "./dist/copilot.es.js",
      "require": "./dist/copilot.cjs"
    },
    "./copilot/style.css": "./dist/copilot.css",
    "./style.css": "./dist/vue-ui.css"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vite build --config vite.copilot.config.ts",
    "test": "vitest run",
    "test:visual": "playwright test",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.57",
    "chart.js": "^4.5.1",
    "vue": "^3.5.12"
  },
  "peerDependencies": {
    "@copilotkit/vue": "^1.60.1",
    "vue": "^3.5.12"
  },
  "peerDependenciesMeta": {
    "@copilotkit/vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/language-core": "~3.1.5",
    "typescript": "^5.9.3",
    "unplugin-dts": "^1.0.1",
    "vite": "^8.0.16"
  }
}
