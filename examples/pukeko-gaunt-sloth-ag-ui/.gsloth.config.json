{
  "llm": {
    "type": "openai",
    "model": "gpt-5.4",
    "configuration": {
      "temperature": 0.7
    }
  },
  "builtInTools": ["show_a2ui_surface"],
  "middleware": ["frontend-image-injection"],
  "streamOutput": true,
  "commands": {
    "api": {
      "port": 3000,
      "cors": {
        "allowOrigin": "http://localhost:5555",
        "allowMethods": "POST, GET, OPTIONS",
        "allowHeaders": "Content-Type, Accept"
      }
    }
  }
}
